{
  "name": "zdrave-cesko-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "HSPA dashboard for Czech Republic - live data from UZIS, CSU, OECD, Eurostat",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "ingest": "node ingest/run.js",
    "ingest:nrpzs": "node ingest/fetchers/uzis_nrpzs.js",
    "ingest:csu": "node ingest/fetchers/csu.js",
    "ingest:oecd": "node ingest/fetchers/oecd.js",
    "ingest:eurostat": "node ingest/fetchers/eurostat.js",
    "transform": "node ingest/transform.js",
    "serve": "npx http-server . -p 8080 -c-1",
    "test": "node --test tests/*.test.js",
    "validate:data": "node ingest/validate.js",
    "validate:strategies": "node ingest/validate-strategies.js",
    "validate:explainers": "node ingest/validate-explainers.js",
    "validate:prevention": "node ingest/validate-prevention.js",
    "validate:all": "node ingest/validate.js && node ingest/validate-strategies.js && node ingest/validate-explainers.js && node ingest/validate-prevention.js",
    "verify:freshness": "node ingest/verify-freshness.js",
    "verify:freshness:report": "node ingest/verify-freshness.js --report-only"
  },
  "dependencies": {
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "http-server": "^14.1.1"
  }
}
